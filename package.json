    "uglifyjs-webpack-plugin": "^1.3.0",
    "url-loader": "~2.3.0",
    "webpack": "~3.10.0",
    "webpack-assets-manifest": "^1.0.0",
    "webpack-dev-middleware": "~2.0.4",
    "webpack-hot-middleware": "^2.22.3",
    "webpack-merge": "~4.1.4",
    "yargs": "^16.1.0"
  },
  "dependencies": {
    "axios": "^0.27.2",
    "jquery": "^3.3.1",
